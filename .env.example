# ==============================================================================
# OpenSourcePilot — Environment Configuration
# Copy this file to .env and fill in your values.
# ==============================================================================

# ------------------------------------------------------------------------------
# LLM Provider
# Options: openrouter | openai | anthropic
# ------------------------------------------------------------------------------
LLM_PROVIDER=openrouter

# OpenRouter (default provider — https://openrouter.ai)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-haiku

 # OpenAI (optional, used when LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# # Anthropic (optional, used when LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ------------------------------------------------------------------------------
# GitHub
# Optional but strongly recommended to avoid API rate limits (60 req/hr unauth)
# Create a token at: https://github.com/settings/tokens (public_repo scope)
# ------------------------------------------------------------------------------
GITHUB_TOKEN=

# ------------------------------------------------------------------------------
# Storage
# ------------------------------------------------------------------------------
# Directory where repositories will be cloned (relative or absolute path)
CLONE_BASE_DIR=./cloned_repos

# Directory where ChromaDB will persist its vector index
CHROMA_PERSIST_DIR=./chroma_db

# ------------------------------------------------------------------------------
# Indexing Limits
# ------------------------------------------------------------------------------
# Maximum number of source files to index per repository
MAX_FILES_TO_INDEX=500

# Maximum individual file size in KB to index (files larger than this are skipped)
MAX_FILE_SIZE_KB=512

# Chunk size in characters for splitting code files
CHUNK_SIZE_CHARS=2000

# Character overlap between consecutive chunks
CHUNK_OVERLAP_CHARS=200

# ChromaDB embedding model (local, no external API cost)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
# Options: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Options: json | console
LOG_FORMAT=console
